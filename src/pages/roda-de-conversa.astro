---
import Layout from '../layouts/Layout.astro';

const whatsappUrl =
  'https://api.whatsapp.com/send?phone=5571981357004&text=Ol%C3%A1%2C+gostaria+de+uma+proposta+da+Escutaris';

const temas = [
  'Como reconhecer sinais de adoecimento na equipe antes do afastamento',
  'O líder como primeiro respondedor em saúde mental — o que fazer e o que não fazer',
  'Gestão de conflitos que ultrapassam a linha do assédio',
  'Retorno ao trabalho após afastamento por transtorno mental — acolhimento sem estigma',
  'Como falar sobre saúde mental com a equipe sem banalizar o tema',
];

const formatos = [
  {
    titulo: 'Sessão Única',
    duracao: '2h a 3h',
    publico: 'Grupo de 8 a 15 líderes',
    inclui: [
      'Facilitação conduzida pela Dra. Ana Paula Teixeira',
      'Material de apoio',
      'Síntese executiva da sessão',
    ],
  },
  {
    titulo: 'Programa (4 sessões)',
    duracao: '4 encontros de 2h (mensal ou quinzenal)',
    publico: 'Mesmo grupo de 8 a 15 líderes',
    inclui: [
      'Quatro sessões facilitadas',
      'Materiais de apoio para cada encontro',
      'Relatório evolutivo do grupo',
    ],
  },
];

const diferenciais = [
  {
    titulo: 'Reflexão estruturada',
    texto:
      'Não é palestra. É um espaço guiado onde a liderança nomeia o que observa no dia a dia e organiza essa percepção com método.',
  },
  {
    titulo: 'Casos reais, anonimizados',
    texto:
      'A discussão parte de situações concretas — sempre anonimizadas — para que o aprendizado seja aplicável ao contexto real da equipe.',
  },
  {
    titulo: 'Ferramentas de ação',
    texto:
      'Cada grupo sai com instrumentos concretos para agir: o que observar, o que dizer e quando encaminhar.',
  },
];

const siteUrl = 'https://www.escutaris.com.br';
const pageUrl = `${siteUrl}/roda-de-conversa`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Service',
      '@id': `${pageUrl}#service`,
      name: 'Rodas de Conversa para Lideranças',
      serviceType: 'Roda de conversa para lideranças em saúde mental no trabalho',
      provider: { '@id': `${siteUrl}/#organization` },
      areaServed: 'BR',
      url: pageUrl,
      description:
        'Rodas de conversa para grupos de líderes e gestores, facilitadas pela Dra. Ana Paula Teixeira (CRM-BA 12797): reflexão estruturada sobre saúde mental no trabalho, casos reais anonimizados e ferramentas concretas de ação.',
    },
  ],
};
---

<Layout
  title="Rodas de Conversa para Lideranças em Saúde Mental | Escutaris"
  description="Rodas de conversa para grupos de líderes e gestores, facilitadas pela Dra. Ana Paula Teixeira (CRM-BA 12797). Reflexão estruturada, casos reais anonimizados e ferramentas concretas de ação em saúde mental no trabalho."
  canonical={pageUrl}
>
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(jsonLd)}
    is:inline
  />

  <!-- HERO -->
  <section class="bg-brand-off-white">
    <div class="container-soft py-16 md:py-24">
      <nav class="mb-8 text-xs uppercase tracking-[0.14em] text-brand-muted" aria-label="Trilha">
        <a href="/" class="hover:text-brand-terracota transition-colors">Início</a>
        <span class="mx-2" aria-hidden="true">/</span>
        <span>Rodas de Conversa</span>
      </nav>

      <div class="max-w-4xl">
        <span class="eyebrow mb-5 block">Formato íntimo para lideranças</span>
        <h1 class="text-4xl md:text-5xl lg:text-[3.5rem] font-display font-bold mb-6 leading-[1.08] text-brand-dark">
          Um espaço de <span class="text-brand-green">reflexão estruturada</span> para quem lidera pessoas.
        </h1>
        <p class="text-lg md:text-xl text-brand-muted leading-relaxed mb-10 max-w-3xl">
          Formato íntimo e profundo, desenhado para grupos de líderes e gestores e
          facilitado pela Dra. Ana Paula Teixeira (CRM-BA 12797). Não é palestra — é um
          espaço onde a liderança nomeia o que observa, discute casos reais anonimizados
          e sai com ferramentas concretas de ação.
        </p>
        <div class="flex flex-wrap gap-3">
          <a href="/#contato" class="btn-primary">
            Solicite uma proposta
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </a>
          <a href={whatsappUrl} target="_blank" rel="noopener" class="btn-whatsapp">
            Falar no WhatsApp
          </a>
        </div>
      </div>
    </div>

    <div class="border-y border-brand-border bg-white">
      <div class="container-soft">
        <div class="grid grid-cols-2 md:grid-cols-4 divide-y md:divide-y-0 md:divide-x divide-brand-border">
          {[
            { n: '8–15', l: 'Líderes por grupo' },
            { n: '2', l: 'Formatos disponíveis' },
            { n: 'CRM-BA', l: 'Facilitação por médica do trabalho' },
            { n: 'NR-1', l: 'Alinhada à norma em vigor' },
          ].map((s) => (
            <div class="py-8 md:py-10 px-6 text-center md:text-left">
              <p class="font-display text-3xl md:text-4xl font-bold text-brand-green mb-1.5 leading-none tabular-nums">
                {s.n}
              </p>
              <p class="text-sm text-brand-muted leading-snug">{s.l}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- IMAGEM MOLDURA -->
  <div class="container-soft pt-16 md:pt-20">
    <img
      src="/roda-conversa-grupo.webp"
      alt="Grupo de profissionais reunido em uma roda de conversa"
      width="1672"
      height="941"
      loading="lazy"
      class="reveal w-full h-auto max-h-[440px] object-cover border border-brand-border"
    />
  </div>

  <!-- O QUE É -->
  <section class="section-pad bg-white">
    <div class="container-soft">
      <div class="reveal max-w-4xl mb-16 md:mb-20">
        <span class="eyebrow mb-5">O que é</span>
        <h2 class="text-3xl md:text-5xl font-display font-bold mb-6 leading-[1.1] text-brand-dark">
          Não é palestra. É reflexão guiada com método.
        </h2>
        <p class="text-lg md:text-xl text-brand-muted leading-relaxed">
          A facilitação parte do que a própria liderança vive e observa, ancorada no
          framework da OMS/OIT e na urgência da NR-1. O resultado é uma compreensão
          aplicável, não conteúdo genérico.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 border border-brand-border bg-brand-off-white">
        {diferenciais.map((d, i) => (
          <article class:list={[
            'reveal p-8 md:p-10',
            i < diferenciais.length - 1 && 'border-b md:border-b-0 md:border-r border-brand-border',
          ]}>
            <div class="w-10 h-1 bg-brand-terracota mb-6" aria-hidden="true"></div>
            <h3 class="text-xl font-display font-bold text-brand-dark mb-3 leading-tight">
              {d.titulo}
            </h3>
            <p class="text-sm text-brand-muted leading-relaxed">{d.texto}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- TEMAS RECORRENTES -->
  <section class="section-pad bg-brand-off-white">
    <div class="container-soft">
      <div class="reveal max-w-4xl mb-16 md:mb-20">
        <span class="eyebrow mb-5">Temas recorrentes</span>
        <h2 class="text-3xl md:text-5xl font-display font-bold mb-6 leading-[1.1] text-brand-dark">
          As conversas que a liderança precisa ter.
        </h2>
        <p class="text-lg md:text-xl text-brand-muted leading-relaxed">
          Os temas são selecionados conforme o momento do grupo. Estes são os que
          aparecem com mais frequência na gestão de equipes.
        </p>
      </div>

      <div class="max-w-4xl border-t border-brand-border">
        {temas.map((tema, i) => (
          <div class="reveal flex items-start gap-6 py-7 border-b border-brand-border">
            <span class="font-display text-2xl md:text-3xl font-bold text-brand-terracota leading-none flex-shrink-0 tabular-nums w-12">
              0{i + 1}
            </span>
            <p class="text-lg text-brand-dark leading-relaxed">{tema}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FORMATOS -->
  <section class="section-pad bg-white">
    <div class="container-soft">
      <div class="reveal max-w-4xl mb-16 md:mb-20">
        <span class="eyebrow mb-5">Formatos</span>
        <h2 class="text-3xl md:text-5xl font-display font-bold mb-6 leading-[1.1] text-brand-dark">
          Um encontro pontual ou um percurso de quatro sessões.
        </h2>
        <p class="text-lg md:text-xl text-brand-muted leading-relaxed">
          Da sessão única, para um tema específico, ao programa continuado, que acompanha
          a evolução do mesmo grupo ao longo do tempo.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 border border-brand-border bg-brand-off-white">
        {formatos.map((f, i) => (
          <article class:list={[
            'reveal p-8 md:p-12 border-brand-border',
            i === 0 && 'border-b md:border-b-0 md:border-r',
          ]}>
            <div class="w-10 h-1 bg-brand-terracota mb-6" aria-hidden="true"></div>
            <h3 class="text-2xl font-display font-bold text-brand-dark mb-6 leading-tight">
              {f.titulo}
            </h3>
            <dl class="space-y-4 mb-8">
              <div class="flex items-baseline gap-3">
                <dt class="text-xs uppercase tracking-[0.14em] text-brand-muted w-20 flex-shrink-0">Duração</dt>
                <dd class="text-brand-dark font-medium">{f.duracao}</dd>
              </div>
              <div class="flex items-baseline gap-3">
                <dt class="text-xs uppercase tracking-[0.14em] text-brand-muted w-20 flex-shrink-0">Grupo</dt>
                <dd class="text-brand-dark font-medium">{f.publico}</dd>
              </div>
            </dl>
            <p class="text-xs uppercase tracking-[0.14em] text-brand-muted mb-3">Inclui</p>
            <ul class="space-y-3">
              {f.inclui.map((item) => (
                <li class="flex items-start gap-3">
                  <span class="text-brand-terracota font-bold mt-0.5 flex-shrink-0" aria-hidden="true">·</span>
                  <span class="text-brand-dark leading-relaxed">{item}</span>
                </li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA FINAL -->
  <section class="section-pad bg-brand-off-white-warm">
    <div class="container-soft">
      <div class="border border-brand-border bg-white p-8 md:p-14 text-center max-w-4xl mx-auto">
        <span class="eyebrow mb-4 block">Vamos conversar</span>
        <h2 class="text-3xl md:text-4xl font-display font-bold text-brand-dark mb-5 leading-tight">
          Crie um espaço de cuidado e ação para quem lidera.
        </h2>
        <p class="text-brand-muted leading-relaxed mb-8 max-w-2xl mx-auto">
          Conte para a gente o perfil do grupo e o momento da sua organização. Montamos
          uma proposta de roda de conversa sob medida para o seu contexto.
        </p>
        <div class="flex flex-wrap gap-3 justify-center">
          <a href="/#contato" class="btn-primary">
            Solicite uma proposta
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </a>
          <a href={whatsappUrl} target="_blank" rel="noopener" class="btn-whatsapp">
            Falar no WhatsApp
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
