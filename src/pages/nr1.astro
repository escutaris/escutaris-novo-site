                    <span class={linha.nada ? 'text-brand-green text-xl font-bold' : 'text-brand-muted text-xl'} aria-label={linha.nada ? 'Sim' : 'Não'}>
                      {linha.nada ? '✓' : '✗'}
                    </span>
                  )}
                </td>
              </tr>
            ))}
