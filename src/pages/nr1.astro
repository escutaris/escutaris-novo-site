                    </span>
                  )}
                </td>
                <td class="p-4">
                  {typeof linha.clima === 'string' ? (
                    <span class="text-sm text-brand-muted">{linha.clima}</span>
                  ) : linha.clima === 'parcial' ? (
                    <span class="text-sm text-brand-muted">Parcial</span>
                  ) : (
                    <span class={linha.clima ? 'text-brand-green text-xl font-bold' : 'text-brand-muted text-xl'} aria-label={linha.clima ? 'Sim' : 'Não'}>
