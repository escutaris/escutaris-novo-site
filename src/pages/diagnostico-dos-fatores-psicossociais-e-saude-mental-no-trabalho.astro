---
import Layout from '../layouts/Layout.astro';

const whatsappUrl =
  'https://api.whatsapp.com/send?phone=5571981357004&text=Ol%C3%A1%2C+quero+contratar+o+diagn%C3%B3stico+psicossocial+da+Escutaris';

const questionarios = [
  {
    sigla: 'HSE',
    nome: 'HSE Indicator Tool',
    destaque: 'Recomendado',
    mede: 'Fatores psicossociais de risco no trabalho — instrumento validado que subsidia a identificação e a avaliação exigidas pela NR-1.',
    venda:
      'Desenvolvido pelo órgão oficial de saúde e segurança do governo britânico, é referência internacional na área e cobre as principais dimensões da gestão de fatores psicossociais, integrado à análise das condições reais de trabalho. É por ele que recomendamos começar.',
  },
  {
    sigla: 'Seg. Psicológica',
    nome: 'Segurança Psicológica',
    destaque: 'Recomendado',
    mede: 'O quanto as pessoas se sentem à vontade para se expressar, errar e pedir ajuda sem medo de retaliação.',
    venda:
      'O par ideal do HSE: equipes psicologicamente seguras falam antes de adoecer, aprendem mais rápido e sustentam qualquer mudança. É o termômetro mais direto da cultura da sua empresa.',
  },
  {
    sigla: 'ERI',
    nome: 'Esforço-Recompensa',
    mede: 'O desequilíbrio entre o esforço dedicado ao trabalho e o reconhecimento recebido em troca.',
  },
  {
    sigla: 'JCQ',
    nome: 'Job Content Questionnaire',
    mede: 'A relação entre demanda, controle sobre o próprio trabalho e apoio social — um dos modelos mais consolidados da área.',
  },
];

const dashboardFeatures = [
  'Filtros por setor, função, jornada, período e tempo de serviço',
  'Análise por geração (Z, Y, X e Alfa) e por gênero',
  'Detalhamento de setor até a função, de forma interativa',
  'Resultado geral consolidado em uma única visão',
  'Exportação para CSV, Excel e Planilhas Google',
  'Modo de apresentação para reuniões e telas',
];

const desdobramentos = [
  {
    titulo: 'Assessoria',
    texto:
      'Apoio técnico para interpretar os achados e construir um plano de ação factível, com metas de curto, médio e longo prazo.',
  },
  {
    titulo: 'Grupo de conversa',
    texto:
      'Escuta qualitativa que complementa os números, aprofundando o entendimento sobre o que as pessoas estão vivendo.',
  },
  {
    titulo: 'Acompanhamento contínuo',
    texto:
      'Reaplicação periódica dos questionários para comparar a evolução ao longo do tempo. Formato negociado conforme a sua necessidade.',
  },
];

const faqs = [
  {
    q: 'O diagnóstico atende à NR-1?',
    a: 'Sim. O diagnóstico é estruturado conforme os critérios da NR-1 sobre fatores psicossociais de risco, e o relatório técnico fornece subsídios para o plano de ação e para a documentação do PGR.',
  },
  {
    q: 'A pesquisa é mesmo anônima?',
    a: 'Sim. A plataforma não coleta identificadores diretos de quem responde, e os resultados são sempre apresentados de forma agregada — nunca individuais.',
  },
  {
    q: 'Em quanto tempo recebo os resultados?',
    a: 'Você recebe o dashboard interativo em até 72 horas após o fechamento da pesquisa. O relatório técnico, elaborado pela nossa equipe, é entregue na sequência.',
  },
  {
    q: 'Quanto custa o diagnóstico?',
    a: 'O investimento depende do número de colaboradores e do objetivo da organização — por isso elaboramos uma proposta sob medida. A conversa de alinhamento é gratuita e sem compromisso: nela você recebe a proposta exata para o seu caso.',
  },
  {
    q: 'Quem aplica os questionários?',
    a: 'A Escutaris conduz todo o processo. A sua empresa apenas distribui o link da pesquisa aos colaboradores; nós cuidamos do processamento, da entrega e da devolutiva.',
  },
  {
    q: 'Quais questionários são utilizados?',
    a: 'Trabalhamos com quatro instrumentos cientificamente validados: HSE, Segurança Psicológica, ERI e JCQ. Para a maioria das empresas, recomendamos o HSE — referência internacional para fatores psicossociais — combinado ao de Segurança Psicológica; os demais entram conforme o objetivo da organização.',
  },
];

const siteUrl = 'https://www.escutaris.com.br';
const pageUrl = `${siteUrl}/diagnostico-dos-fatores-psicossociais-e-saude-mental-no-trabalho`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Service',
      '@id': `${pageUrl}#service`,
      name: 'Diagnóstico de Fatores Psicossociais e Saúde Mental no Trabalho',
      serviceType: 'Diagnóstico psicossocial (NR-1)',
      provider: { '@id': `${siteUrl}/#organization` },
      areaServed: 'BR',
      url: pageUrl,
      description:
        'Diagnóstico de fatores psicossociais conduzido como serviço pela Escutaris: questionários cientificamente validados, processo anonimizado e dashboard interativo entregue em até 72 horas.',
    },
    {
      '@type': 'FAQPage',
      '@id': `${pageUrl}#faq`,
      mainEntity: faqs.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    },
  ],
};
---

<Layout
  title="Diagnóstico de Fatores Psicossociais e Saúde Mental no Trabalho | Escutaris"
  description="Diagnóstico psicossocial conduzido pela Escutaris: questionários validados (HSE, Segurança Psicológica, ERI, JCQ), processo anônimo e dashboard interativo em até 72 horas. Conformidade com a NR-1."
  canonical={pageUrl}
  ogImage="/dashboard-karasek.webp"
>
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(jsonLd)}
    is:inline
  />

  <!-- HERO -->
  <section class="bg-brand-off-white">
    <div class="container-soft py-16 md:py-24">
      <nav class="mb-8 text-xs uppercase tracking-[0.14em] text-brand-muted" aria-label="Trilha">
        <a href="/" class="hover:text-brand-terracota transition-colors">Início</a>
        <span class="mx-2" aria-hidden="true">/</span>
        <span>Diagnóstico Psicossocial</span>
      </nav>

      <div class="max-w-4xl">
        <h1 class="text-4xl md:text-5xl lg:text-[3.5rem] font-display font-bold mb-6 leading-[1.08] text-brand-dark">
          A avaliação psicossocial para a gestão que a <span class="text-brand-green">NR-1</span> exige, conduzida de ponta a ponta.
        </h1>
        <p class="text-lg md:text-xl text-brand-muted leading-relaxed mb-10 max-w-3xl">
          A Escutaris conduz o diagnóstico como serviço: você contrata, nós aplicamos e
          entregamos o dashboard interativo e o relatório técnico da nossa equipe, sob
          responsabilidade da Dra. Ana Paula Teixeira. Questionários cientificamente
          validados, processo anonimizado e dashboard em até 72 horas.
        </p>
        <div class="flex flex-wrap gap-3">
          <a href="/#contato" class="btn-primary">
            Iniciar diagnóstico
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </a>
          <a href={whatsappUrl} target="_blank" rel="noopener" class="btn-whatsapp">
            Falar no WhatsApp
          </a>
        </div>
      </div>
    </div>

    <div class="border-y border-brand-border bg-white">
      <div class="container-soft">
        <div class="grid grid-cols-2 md:grid-cols-4 divide-y md:divide-y-0 md:divide-x divide-brand-border">
          {[
            { n: '72h', l: 'Dashboard entregue' },
            { n: '4', l: 'Questionários validados' },
            { n: 'LGPD', l: 'Sem identificadores diretos, resultados agregados' },
            { n: 'NR-1', l: 'Subsídios para o plano de ação e o PGR' },
          ].map((s) => (
            <div class="py-8 md:py-10 px-6 text-center md:text-left">
              <p class="font-display text-3xl md:text-4xl font-bold text-brand-green mb-1.5 leading-none tabular-nums">
                {s.n}
              </p>
              <p class="text-sm text-brand-muted leading-snug">{s.l}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- IMAGEM MOLDURA -->
  <div class="container-soft pt-20 md:pt-24">
    <img
      src="/analise-dados-diagnostico.webp"
      alt="Equipe analisando dados e documentos do diagnóstico psicossocial sobre a mesa"
      width="1672"
      height="941"
      loading="lazy"
      class="reveal w-full h-auto max-h-[460px] object-cover border border-brand-border"
    />
  </div>

  <!-- O QUE VOCÊ RECEBE -->
  <section class="section-pad bg-white">
    <div class="container-soft">
      <div class="reveal max-w-4xl mb-16 md:mb-20">
        <span class="eyebrow mb-5">O que você recebe</span>
        <h2 class="text-3xl md:text-5xl font-display font-bold mb-6 leading-[1.1] text-brand-dark">
          Dois entregáveis: o dado vivo e a análise técnica.
        </h2>
        <p class="text-lg md:text-xl text-brand-muted leading-relaxed">
          O diagnóstico entrega o resultado e a análise dos dados — a base técnica
          para a sua empresa priorizar, decidir e agir.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 border border-brand-border bg-brand-off-white">
        <article class="reveal p-8 md:p-12 border-b lg:border-b-0 lg:border-r border-brand-border">
          <span class="text-[11px] uppercase tracking-[0.18em] text-brand-terracota font-semibold mb-4 block">
            Entregável 1 · O dado vivo
          </span>
          <h3 class="text-2xl md:text-3xl font-display font-bold text-brand-dark mb-4 leading-tight">
            Dashboard interativo
          </h3>
          <p class="text-brand-dark leading-relaxed mb-6">
            Painel entregue em até 72 horas após o fechamento da pesquisa. Em vez de um
            PDF estático, você explora, cruza e filtra os resultados por conta própria —
            a informação viva nas mãos da gestão.
          </p>
          <ul class="space-y-2.5">
            {['Filtros por setor, função, jornada, geração e gênero', 'Do resultado geral ao detalhe de cada função', 'Exportação e modo de apresentação para reuniões'].map((item) => (
              <li class="flex items-start gap-3 text-sm text-brand-dark">
                <span class="text-brand-terracota font-bold mt-0.5 flex-shrink-0" aria-hidden="true">·</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </article>

        <article class="reveal p-8 md:p-12">
          <span class="text-[11px] uppercase tracking-[0.18em] text-brand-green font-semibold mb-4 block">
            Entregável 2 · A análise técnica
          </span>
          <h3 class="text-2xl md:text-3xl font-display font-bold text-brand-dark mb-4 leading-tight">
            Relatório técnico
          </h3>
          <p class="text-brand-dark leading-relaxed mb-6">
            Elaborado pela equipe Escutaris sob responsabilidade técnica da Dra. Ana Paula
            Teixeira (CRM-BA 12797), médica do trabalho: avaliação dos resultados, reflexão
            sobre o contexto da sua organização e propostas para orientar as decisões.
          </p>
          <ul class="space-y-2.5">
            {['Avaliação e interpretação técnica dos resultados', 'Subsídios para a matriz de priorização (probabilidade × severidade)', 'Subsídios para o plano de ação e a documentação do PGR'].map((item) => (
              <li class="flex items-start gap-3 text-sm text-brand-dark">
                <span class="text-brand-green font-bold mt-0.5 flex-shrink-0" aria-hidden="true">·</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </article>
      </div>

      <p class="text-sm text-brand-muted mt-6 max-w-3xl">
        Precisa de uma avaliação organizacional aprofundada, com entrevistas, análise
        documental e adequação completa do PGR? Esse é o trabalho da nossa
        <a href="/consultoria-nr1" class="text-brand-green font-semibold hover:text-brand-terracota transition-colors">Consultoria NR-1/GRO</a>.
      </p>
    </div>
  </section>

  <!-- QUESTIONÁRIOS -->
  <section class="section-pad bg-brand-off-white">
    <div class="container-soft">
      <div class="reveal max-w-4xl mb-16 md:mb-20">
        <span class="eyebrow mb-5">Base científica</span>
        <h2 class="text-3xl md:text-5xl font-display font-bold mb-6 leading-[1.1] text-brand-dark">
          Quatro instrumentos validados, não pesquisa genérica.
        </h2>
        <p class="text-lg md:text-xl text-brand-muted leading-relaxed">
          Selecionamos os questionários conforme o objetivo da sua organização.
          Todos com evidência científica publicada, não improviso de clima — e dois
          deles, o HSE e o de Segurança Psicológica, são os que recomendamos para a
          maioria das empresas.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 border border-brand-border bg-white">
        {questionarios.map((q, i) => (
          <article class:list={[
            'reveal p-8 md:p-12 border-brand-border',
            i < questionarios.length - 1 && 'border-b',
            i >= questionarios.length - 2 && 'md:border-b-0',
            i % 2 === 0 && 'md:border-r',
            q.destaque && 'border-t-2 border-t-brand-terracota bg-brand-off-white-warm',
          ]}>
            <div class="flex items-baseline gap-4 mb-4 flex-wrap">
              <span class="font-display text-2xl md:text-3xl font-bold text-brand-green leading-none">
                {q.sigla}
              </span>
              <span class="text-sm text-brand-muted">{q.nome}</span>
              {q.destaque && (
                <span class="text-[10px] uppercase tracking-[0.16em] font-semibold text-white bg-brand-terracota px-2.5 py-1">
                  {q.destaque}
                </span>
              )}
            </div>
            <p class="text-brand-dark leading-relaxed">{q.mede}</p>
            {q.venda && (
              <p class="text-sm text-brand-muted leading-relaxed mt-4">{q.venda}</p>
            )}
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- DASHBOARD -->
  <section class="section-pad bg-white">
    <div class="container-soft">
      <div class="reveal max-w-4xl mb-16 md:mb-20">
        <span class="eyebrow mb-5">O dashboard</span>
        <h2 class="text-3xl md:text-5xl font-display font-bold mb-6 leading-[1.1] text-brand-dark">
          Resultados que se exploram, não relatório que se arquiva.
        </h2>
        <p class="text-lg md:text-xl text-brand-muted leading-relaxed">
          Um painel interativo onde você filtra, cruza e aprofunda os dados por setor,
          função, jornada e geração — para enxergar onde está o risco e agir com precisão.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-12 items-start">
        <div class="lg:col-span-5">
          <ul class="space-y-4">
            {dashboardFeatures.map((f) => (
              <li class="flex items-start gap-3">
                <span class="text-brand-terracota font-bold mt-0.5 flex-shrink-0" aria-hidden="true">·</span>
                <span class="text-brand-dark leading-relaxed">{f}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="lg:col-span-7 space-y-6">
          <!-- Tela real do painel (dados ilustrativos) -->
          <figure class="border border-brand-border bg-brand-off-white-warm p-4 md:p-6">
            <img
              src="/dashboard-real.webp"
              alt="Painel interativo de diagnóstico psicossocial com filtros, KPIs e gráficos por gênero, jornada, setor e função"
              width="1460"
              height="1240"
              loading="lazy"
              class="w-full h-auto border border-brand-border"
            />
            <figcaption class="text-xs text-brand-muted mt-3 text-center">
              Painel interativo de resultados. Dados ilustrativos.
            </figcaption>
          </figure>

          {/* Espaço reservado para o clipe do dashboard (oculto até o vídeo existir) */}
        </div>
      </div>
    </div>
  </section>

  <!-- SEGURANÇA E LGPD -->
  <section class="relative isolate section-pad text-white overflow-hidden">
    <img
      src="/ambiente-calmo-bem-estar.webp"
      alt=""
      aria-hidden="true"
      width="1672"
      height="941"
      loading="lazy"
      class="absolute inset-0 w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-brand-green/90" aria-hidden="true"></div>
    <div class="relative container-soft">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-center">
        <div class="lg:col-span-7">
          <span class="text-[11px] uppercase tracking-[0.18em] text-white/70 font-semibold mb-4 block">
            Segurança e LGPD
          </span>
          <h2 class="text-3xl md:text-4xl font-display font-bold text-white mb-6 leading-tight">
            Anonimato garantido por arquitetura, não por promessa.
          </h2>
          <p class="text-white/85 leading-relaxed text-lg max-w-2xl">
            Cada resposta é tratada de forma anonimizada: a plataforma não coleta
            identificadores diretos de quem responde. O processamento ocorre
            diariamente em infraestrutura Google Cloud, e os resultados são sempre
            apresentados de forma agregada — nunca individuais —, em conformidade
            com a LGPD.
          </p>
        </div>
        <div class="lg:col-span-5">
          <figure class="bg-white/5 border border-white/15 p-3 mb-6">
            <img
              src="/dashboard-dados.webp"
              alt="Tabela de dados consolidados do diagnóstico, com identificador anônimo no lugar do nome dos participantes"
              width="1000"
              height="563"
              loading="lazy"
              class="w-full h-auto"
            />
            <figcaption class="text-xs text-white/60 mt-2 text-center">
              Os participantes aparecem apenas como código anônimo. Dados ilustrativos.
            </figcaption>
          </figure>
          <div class="border border-white/15 divide-y divide-white/15">
            {[
              ['Anonimato técnico', 'Impossível associar respostas a pessoas'],
              ['Google Cloud', 'Processamento diário em infraestrutura segura'],
              ['Dados agregados', 'Resultados por setor, função e geração — nunca individuais'],
            ].map(([t, d]) => (
              <div class="p-6">
                <p class="font-display font-bold text-white mb-1">{t}</p>
                <p class="text-sm text-white/70 leading-relaxed">{d}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- DEPOIS DO DIAGNÓSTICO -->
  <section class="section-pad bg-brand-off-white">
    <div class="container-soft">
      <div class="reveal max-w-4xl mb-16 md:mb-20">
        <span class="eyebrow mb-5">Depois do diagnóstico</span>
        <h2 class="text-3xl md:text-5xl font-display font-bold mb-6 leading-[1.1] text-brand-dark">
          O número é o começo. O cuidado continua.
        </h2>
        <p class="text-lg md:text-xl text-brand-muted leading-relaxed">
          O diagnóstico abre caminho para a ação. A partir dele, a Escutaris pode
          seguir ao seu lado nos desdobramentos que a sua organização precisar.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 border border-brand-border bg-white">
        {desdobramentos.map((d, i) => (
          <article class:list={[
            'reveal p-8 md:p-10',
            i < desdobramentos.length - 1 && 'border-b md:border-b-0 md:border-r border-brand-border',
          ]}>
            <div class="w-10 h-1 bg-brand-terracota mb-6" aria-hidden="true"></div>
            <h3 class="text-xl font-display font-bold text-brand-dark mb-3 leading-tight">
              {d.titulo}
            </h3>
            <p class="text-sm text-brand-muted leading-relaxed">{d.texto}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section-pad bg-white">
    <div class="container-soft">
      <div class="reveal max-w-4xl mb-16 md:mb-20">
        <span class="eyebrow mb-5">Perguntas frequentes</span>
        <h2 class="text-3xl md:text-5xl font-display font-bold mb-6 leading-[1.1] text-brand-dark">
          O que as empresas costumam perguntar.
        </h2>
      </div>

      <div class="max-w-3xl border-t border-brand-border">
        {faqs.map((f) => (
          <details class="group border-b border-brand-border">
            <summary class="flex items-start justify-between gap-4 py-6 cursor-pointer list-none">
              <span class="font-display font-bold text-brand-dark text-lg leading-snug">
                {f.q}
              </span>
              <span class="text-brand-terracota text-2xl leading-none flex-shrink-0 transition-transform group-open:rotate-45" aria-hidden="true">
                +
              </span>
            </summary>
            <p class="text-brand-muted leading-relaxed pb-6 -mt-1 max-w-2xl">
              {f.a}
            </p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA FINAL -->
  <section class="section-pad bg-brand-off-white-warm">
    <div class="container-soft">
      <div class="border border-brand-border bg-white p-8 md:p-14 text-center max-w-4xl mx-auto">
        <span class="eyebrow mb-4 block">Vamos começar</span>
        <h2 class="text-3xl md:text-4xl font-display font-bold text-brand-dark mb-5 leading-tight">
          Sua empresa já estruturou a gestão dos fatores psicossociais que a NR-1 exige?
        </h2>
        <p class="text-brand-muted leading-relaxed mb-8 max-w-2xl mx-auto">
          Conte para a gente o objetivo da sua organização. Marcamos uma conversa de
          alinhamento e desenhamos o diagnóstico ideal para o seu contexto.
        </p>
        <div class="flex flex-wrap gap-3 justify-center">
          <a href="/#contato" class="btn-primary">
            Iniciar diagnóstico
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </a>
          <a href={whatsappUrl} target="_blank" rel="noopener" class="btn-whatsapp">
            Falar no WhatsApp
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
