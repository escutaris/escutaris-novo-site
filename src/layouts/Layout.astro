---
import '../styles/global.css';
import TopBar from '../components/TopBar.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ScrollTop from '../components/ScrollTop.astro';
import CookieBanner from '../components/CookieBanner.astro';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonical?: string;
}

const {
  title,
  description,
  ogImage = '/hero-banner.webp',
  canonical = Astro.url.href,
} = Astro.props;

const siteUrl = 'https://www.escutaris.com.br';
const ogImageAbsolute = new URL(ogImage, siteUrl).href;

// Dados estruturados (schema.org) — ajudam o Google a entender quem é a Escutaris,
// habilitam resultados ricos e reforçam credibilidade (responsabilidade técnica médica).
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': ['Organization', 'MedicalBusiness'],
      '@id': `${siteUrl}/#organization`,
      name: 'Escutaris',
      legalName: 'Queluz Serviços Médicos Ltda.',
      url: siteUrl,
      logo: `${siteUrl}/logo-escutaris.png`,
      image: ogImageAbsolute,
      description:
        'Plataforma de diagnóstico de fatores psicossociais e saúde mental no trabalho, em conformidade com a NR-1.',
      email: 'contato@escutaris.com.br',
      telephone: '+5571981357004',
      areaServed: 'BR',
      address: {
        '@type': 'PostalAddress',
        addressLocality: 'Salvador',
        addressRegion: 'BA',
        addressCountry: 'BR',
      },
      founder: {
        '@type': 'Person',
        name: 'Dra. Ana Paula Teixeira',
        jobTitle: 'Médica do Trabalho',
        identifier: 'CRM-BA 12797',
      },
    },
    {
      '@type': 'WebSite',
      '@id': `${siteUrl}/#website`,
      url: siteUrl,
      name: 'Escutaris',
      inLanguage: 'pt-BR',
      publisher: { '@id': `${siteUrl}/#organization` },
    },
  ],
};
---

<!doctype html>
<html lang="pt-br">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <link rel="icon" type="image/png" sizes="32x32" href="/favicon.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <link
      rel="preload"
      href="/fonts/garet/Garet-Bold.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageAbsolute} />
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:site_name" content="Escutaris" />
    <meta property="og:url" content={canonical} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbsolute} />

    <meta name="theme-color" content="#46603a" />
    <meta name="author" content="Escutaris" />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />

    <slot name="head" />
  </head>
  <body class="font-body text-brand-dark antialiased min-h-dvh flex flex-col">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[60] focus:px-4 focus:py-2 focus:bg-brand-green focus:text-white"
    >
      Pular para o conteúdo principal
    </a>

    <TopBar />
    <Header />
    <main id="main-content" class="flex-1">
      <slot />
    </main>
    <Footer />
    <ScrollTop />
    <CookieBanner />

    <!-- Tradutor (Google). LGPD: o script do Google só carrega se a pessoa já escolheu
         um idioma (cookie googtrans). A troca grava o cookie e recarrega a página,
         que abre direto traduzida — método mais confiável que disparar o combo. -->
    <div id="google_translate_element" class="hidden" aria-hidden="true"></div>
    <script is:inline>
      (function () {
        function activeLang() {
          var m = document.cookie.match(/(?:^|;\s*)googtrans=([^;]*)/);
          return m ? decodeURIComponent(m[1]).split('/')[2] || '' : '';
        }
        window.googleTranslateElementInit = function () {
          new google.translate.TranslateElement(
            { pageLanguage: 'pt', autoDisplay: false },
            'google_translate_element'
          );
        };
        function loadGT() {
          var s = document.createElement('script');
          s.src = 'https://translate.google.com/translate_a/element.js?cb=googleTranslateElementInit';
          document.body.appendChild(s);
        }
        function setCookie(value) {
          // Grava no host atual e no domínio raiz (o Google às vezes grava com domínio).
          var clear = value === null;
          var exp = clear ? '; expires=Thu, 01 Jan 1970 00:00:00 GMT' : '';
          var val = clear ? '' : value;
          document.cookie = 'googtrans=' + val + exp + '; path=/';
          var parts = location.hostname.split('.');
          while (parts.length > 1) {
            document.cookie = 'googtrans=' + val + exp + '; path=/; domain=.' + parts.join('.');
            parts.shift();
          }
        }
        window.doGTranslate = function (pair) {
          if (pair && typeof pair === 'object' && pair.value) pair = pair.value;
          if (!pair) return;
          var lang = pair.split('|')[1];
          if (lang === 'pt') setCookie(null);
          else setCookie('/pt/' + lang);
          location.reload();
        };
        if (activeLang() && activeLang() !== 'pt') loadGT();
      })();
    </script>
    <style is:global>
      /* Esconde a barra e os balões que o Google Tradutor injeta na página */
      body { top: 0 !important; }
      iframe.skiptranslate,
      .goog-te-banner-frame,
      .VIpgJd-ZVi9od-ORHb-OEVmcd,
      #goog-gt-tt,
      .goog-te-balloon-frame,
      .goog-tooltip,
      .goog-te-spinner-pos { display: none !important; visibility: hidden !important; }
      .goog-text-highlight,
      .VIpgJd-yAWNEb-VIpgJd-fmcmS-sn54Q {
        background: none !important;
        box-shadow: none !important;
      }
      font[style] { background: none !important; }
    </style>

    <script>
      // Reveal suave ao entrar na viewport. Sem biblioteca, respeita prefers-reduced-motion (via CSS).
      const els = document.querySelectorAll<HTMLElement>('.reveal');
      if (els.length > 0 && 'IntersectionObserver' in window) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                io.unobserve(entry.target);
              }
            }
          },
          { rootMargin: '0px 0px -10% 0px', threshold: 0.1 }
        );
        els.forEach((el) => io.observe(el));
      } else {
        els.forEach((el) => el.classList.add('is-visible'));
      }
    </script>

    <script>
      // Números que sobem de 0 até o alvo (estilo cronômetro) quando entram na tela.
      // Suporta data-prefix / data-suffix / data-decimals. Respeita prefers-reduced-motion.
      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const easeOutCubic = (t: number) => 1 - Math.pow(1 - t, 3);

      function animateCounter(el: HTMLElement) {
        const target = parseFloat(el.dataset.target ?? '');
        if (Number.isNaN(target)) return;
        const duration = parseInt(el.dataset.duration ?? '1600', 10);
        const decimals = parseInt(el.dataset.decimals ?? '0', 10);
        const prefix = el.dataset.prefix ?? '';
        const suffix = el.dataset.suffix ?? '';
        const fmt = (v: number) =>
          prefix +
          v.toLocaleString('pt-BR', { minimumFractionDigits: decimals, maximumFractionDigits: decimals }) +
          suffix;

        if (prefersReduced) {
          el.textContent = fmt(target);
          return;
        }

        const start = performance.now();
        const tick = (now: number) => {
          const t = Math.min(1, (now - start) / duration);
          el.textContent = fmt(target * easeOutCubic(t));
          if (t < 1) requestAnimationFrame(tick);
        };
        requestAnimationFrame(tick);
      }

      const counters = document.querySelectorAll<HTMLElement>('[data-counter]');
      if (counters.length > 0) {
        if ('IntersectionObserver' in window) {
          const io = new IntersectionObserver(
            (entries) => {
              for (const entry of entries) {
                if (entry.isIntersecting) {
                  animateCounter(entry.target as HTMLElement);
                  io.unobserve(entry.target);
                }
              }
            },
            { threshold: 0.5 }
          );
          counters.forEach((el) => io.observe(el));
        } else {
          counters.forEach((el) => animateCounter(el));
        }
      }
    </script>
  </body>
</html>
