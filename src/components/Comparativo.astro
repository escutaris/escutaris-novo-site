---
const criterios = [
  { label: 'Atende à NR-1 e gera documentação para o PGR', nada: 'nao', generica: 'parcial', escutaris: 'sim' },
  { label: 'Instrumentos cientificamente validados', nada: 'nao', generica: 'parcial', escutaris: 'sim' },
  { label: 'Anonimato garantido por arquitetura (LGPD)', nada: 'nao', generica: 'parcial', escutaris: 'sim' },
  { label: 'Análise por setor, função e geração', nada: 'nao', generica: 'parcial', escutaris: 'sim' },
  { label: 'Plano de ação e devolutiva técnica', nada: 'nao', generica: 'nao', escutaris: 'sim' },
  { label: 'Reduz risco de autuação e passivo trabalhista', nada: 'nao', generica: 'parcial', escutaris: 'sim' },
];

const colClass = 'p-4 md:p-5 text-center align-middle';
---

<section class="section-pad bg-brand-off-white">
  <div class="container-soft">
    <div class="reveal max-w-4xl mb-16 md:mb-20">
      <h2 class="text-3xl md:text-5xl font-display font-bold mb-6 leading-[1.1] text-brand-dark">
        A diferença entre medir e diagnosticar.
      </h2>
      <p class="text-lg md:text-xl text-brand-muted leading-relaxed">
        Não agir custa caro, e uma pesquisa de clima genérica não atende à NR-1.
        Veja o que separa um diagnóstico psicossocial sério das alternativas.
      </p>
    </div>

    <p class="md:hidden text-xs text-brand-muted mb-3">
      Arraste a tabela para o lado para ver todas as colunas.
    </p>

    <div class="reveal overflow-x-auto border border-brand-border bg-white">
      <table class="w-full min-w-[680px] border-collapse text-sm">
        <thead>
          <tr class="border-b border-brand-border">
            <th class="p-4 md:p-5 text-left font-display text-brand-dark w-2/5">&nbsp;</th>
            <th class="p-4 md:p-5 text-center font-display font-bold text-brand-muted">Não fazer nada</th>
            <th class="p-4 md:p-5 text-center font-display font-bold text-brand-muted">Pesquisa de clima genérica</th>
            <th class="p-4 md:p-5 text-center font-display font-bold text-white bg-brand-green">Diagnóstico Escutaris</th>
          </tr>
        </thead>
        <tbody>
          {criterios.map((row, i) => (
            <tr class:list={[i < criterios.length - 1 && 'border-b border-brand-border']}>
              <td class="p-4 md:p-5 text-left text-brand-dark font-medium leading-snug">{row.label}</td>
              <td class={colClass}>
                <span class="sr-only">{row.nada === 'sim' ? 'Sim' : row.nada === 'parcial' ? 'Parcial' : 'Não'}</span>
                {row.nada === 'sim' ? (
                  <svg class="w-5 h-5 inline text-brand-green" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
                ) : row.nada === 'parcial' ? (
                  <span class="inline-block w-4 h-0.5 bg-brand-muted/50" aria-hidden="true"></span>
                ) : (
                  <svg class="w-5 h-5 inline text-brand-muted/50" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12" /></svg>
                )}
              </td>
              <td class={colClass}>
                <span class="sr-only">{row.generica === 'sim' ? 'Sim' : row.generica === 'parcial' ? 'Parcial' : 'Não'}</span>
                {row.generica === 'sim' ? (
                  <svg class="w-5 h-5 inline text-brand-green" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
                ) : row.generica === 'parcial' ? (
                  <span class="inline-block w-4 h-0.5 bg-brand-muted/50" aria-hidden="true"></span>
                ) : (
                  <svg class="w-5 h-5 inline text-brand-muted/50" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12" /></svg>
                )}
              </td>
              <td class:list={[colClass, 'bg-brand-green/5']}>
                <span class="sr-only">{row.escutaris === 'sim' ? 'Sim' : row.escutaris === 'parcial' ? 'Parcial' : 'Não'}</span>
                {row.escutaris === 'sim' ? (
                  <svg class="w-5 h-5 inline text-brand-green" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
                ) : row.escutaris === 'parcial' ? (
                  <span class="inline-block w-4 h-0.5 bg-brand-muted/50" aria-hidden="true"></span>
                ) : (
                  <svg class="w-5 h-5 inline text-brand-muted/50" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12" /></svg>
                )}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>
