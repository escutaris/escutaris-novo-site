      <div class="md:col-span-3">
        <h3 class="text-white font-display font-bold text-sm uppercase tracking-wider mb-5">Navegação</h3>
        <ul class="space-y-3 text-[15px]">
          <li><a href="/" class="text-white/75 hover:text-white transition-colors">Início</a></li>
          <li><a href="/sobre" class="text-white/75 hover:text-white transition-colors">Sobre</a></li>
          <li><a href="/#servicos" class="text-white/75 hover:text-white transition-colors">Serviços</a></li>
          <li><a href="/blog" class="text-white/75 hover:text-white transition-colors">Blog</a></li>
          <li><a href="/#contato" class="text-white/75 hover:text-white transition-colors">Contato</a></li>
        </ul>
      </div>

      <div class="md:col-span-4">
        <h3 class="text-white font-display font-bold text-sm uppercase tracking-wider mb-5">Contato</h3>
        <ul class="space-y-3 text-[15px] text-white/85">
          <li>
            <a href="https://api.whatsapp.com/send?phone=5571981357004" target="_blank" rel="noopener" class="hover:text-white transition-colors">
              WhatsApp · (71) 98135-7004
            </a>
          </li>
          <li>
            <a href="mailto:contato@escutaris.com.br" class="hover:text-white transition-colors">
              contato@escutaris.com.br
            </a>
          </li>
          <li class="text-white/70 text-sm">Salvador, Bahia</li>
        </ul>

        <div class="mt-8 pt-6 border-t border-white/15">
          <p class="text-[11px] uppercase tracking-[0.18em] text-white/60 mb-3">Publicação</p>
          <a
            href="https://amzn.to/49KJXQw"
            target="_blank"
            rel="noopener"
            class="flex items-start gap-4 group"
          >
            <img
              src="/livro-capa.webp"
              alt="Capa do livro Quando o Trabalho Dói, de Ana Paula Teixeira"
              width="415"
              height="624"
              loading="lazy"
              class="w-16 h-auto border border-white/20 flex-shrink-0 group-hover:opacity-90 transition-opacity"
            />
            <span class="min-w-0">
              <span class="font-display font-bold text-white group-hover:text-white/80 transition-colors block">
                Quando o Trabalho Dói →
              </span>
              <span class="text-xs text-white/65 mt-1 block">Dra. Ana Paula Teixeira · Assedionet, 2025</span>
              <span class="text-xs text-white/50 mt-1 block">Disponível na Amazon</span>
            </span>
          </a>
        </div>
      </div>
    </div>

    <div class="border-t border-white/15 mt-14 pt-6 flex flex-col md:flex-row gap-3 justify-between items-center text-xs text-white/65">
      <p>© {year} Escutaris · Queluz Serviços Médicos Ltda.</p>
      <div class="flex gap-6">
        <a href="/politica-de-privacidade" class="hover:text-white transition-colors">Política de Privacidade</a>
        <a href="/politica-de-privacidade#cookies" class="hover:text-white transition-colors">Cookies</a>
      </div>
    </div>
  </div>
</footer>
