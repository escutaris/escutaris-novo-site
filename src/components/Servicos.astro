---
const servicosSecundarios = [
  {
    eyebrow: 'Sensibilizar',
    titulo: 'Palestras',
    descricao:
      'Intervenções de sensibilização baseadas em evidências — não motivacionais — para despertar a liderança sobre saúde mental e NR-1.',
    href: '/palestra',
  },
  {
    eyebrow: 'Sensibilizar',
    titulo: 'Rodas de Conversa',
    descricao:
      'Espaço de reflexão estruturada para líderes nomearem o que observam e saírem com ferramentas concretas de ação.',
    href: '/roda-de-conversa',
  },
  {
    eyebrow: 'Capacitar',
    titulo: 'Treinamentos',
    descricao:
      'Capacitação técnica com carga horária e avaliação de aprendizado, do papel do líder à implementação do GRO psicossocial.',
    href: '/treinamentos',
  },
  {
    eyebrow: 'Transformar',
    titulo: 'Programa Contínuo',
    descricao:
      'Gestão permanente de saúde mental: diagnóstico, intervenção, monitoramento e reavaliação em ciclo anual.',
    href: '/programa-continuo',
  },
  {
    eyebrow: 'Transformar',
    titulo: 'Consultoria NR-1/GRO',
    descricao:
      'Projeto de escopo definido para adequar a empresa rapidamente às exigências da NR-1, com documentação para fiscalização.',
    href: '/consultoria-nr1',
  },
];
---

<section id="servicos" class="section-pad bg-brand-off-white">
  <div class="container-soft">
    <div class="reveal max-w-4xl mb-16 md:mb-20">
      <h2 class="text-3xl md:text-5xl font-display font-bold mb-6 leading-[1.1] text-brand-dark">
        Do primeiro alerta à transformação da cultura.
      </h2>
      <p class="text-lg md:text-xl text-brand-muted leading-relaxed">
        Uma arquitetura de soluções que acompanha a sua organização em cada estágio:
        sensibilizar a liderança, capacitar as equipes, diagnosticar os riscos e
        transformar a cultura de forma contínua.
      </p>
    </div>

    <article class="bg-white border border-brand-border mb-12 relative">
      <div class="absolute top-0 left-0 w-32 h-1 bg-brand-terracota" aria-hidden="true"></div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-0">
        <div class="lg:col-span-7 p-8 md:p-12 lg:p-14 lg:border-r border-brand-border">
          <span class="eyebrow mb-4 block">Produto principal · Diagnóstico</span>

          <h3 class="text-3xl md:text-4xl font-display font-bold text-brand-dark mb-5 leading-tight">
            Diagnóstico Psicossocial
          </h3>

          <p class="text-base md:text-lg text-brand-dark mb-6 leading-relaxed">
            Avaliação dos fatores psicossociais e da saúde mental no trabalho, em dois níveis:
            a plataforma com questionários validados e dashboard em até 72 horas, ou a consultoria
            organizacional aprofundada com base nos 10 domínios da OMS/OIT. Processo anonimizado e
            em conformidade integral com a NR-1.
          </p>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-3 mb-8">
            <div class="flex items-start gap-3 text-sm">
              <span class="text-brand-terracota font-bold mt-0.5" aria-hidden="true">·</span>
              <span class="text-brand-dark"><strong class="font-semibold">Conformidade integral</strong> com NR-01 e PGR</span>
            </div>
            <div class="flex items-start gap-3 text-sm">
              <span class="text-brand-terracota font-bold mt-0.5" aria-hidden="true">·</span>
              <span class="text-brand-dark"><strong class="font-semibold">Anonimato e LGPD</strong> garantidos por design</span>
            </div>
            <div class="flex items-start gap-3 text-sm">
              <span class="text-brand-terracota font-bold mt-0.5" aria-hidden="true">·</span>
              <span class="text-brand-dark"><strong class="font-semibold">Análise multifator</strong> por setor, função e geração</span>
            </div>
            <div class="flex items-start gap-3 text-sm">
              <span class="text-brand-terracota font-bold mt-0.5" aria-hidden="true">·</span>
              <span class="text-brand-dark"><strong class="font-semibold">Relatório descritivo</strong> com plano de ação</span>
            </div>
          </div>

          <div class="flex flex-wrap gap-3">
            <a href="#contato" class="btn-primary">
              Iniciar diagnóstico
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
              </svg>
            </a>
            <a href="/diagnostico-dos-fatores-psicossociais-e-saude-mental-no-trabalho" class="btn-ghost">
              Ver detalhes do produto
            </a>
          </div>
        </div>

        <div class="lg:col-span-5 bg-brand-off-white-warm p-8 md:p-12 flex items-center justify-center">
          <img
            src="/dashboard-karasek.webp"
            alt="Dashboard interativo de diagnóstico psicossocial com filtros por setor, função e geração"
            width="640"
            height="360"
            class="w-full h-auto border border-brand-border"
            loading="lazy"
          />
        </div>
      </div>
    </article>

    <p class="text-[11px] uppercase tracking-[0.18em] text-brand-muted font-semibold mb-6">
      Outras frentes da jornada
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 border-t border-l border-brand-border bg-white">
      {servicosSecundarios.map((servico) => (
        <a
          href={servico.href}
          class="group p-8 md:p-10 flex flex-col border-r border-b border-brand-border hover:bg-brand-off-white-warm transition-colors"
        >
          <span class="eyebrow mb-3 block text-[10px]">{servico.eyebrow}</span>

          <h3 class="text-xl font-display font-bold text-brand-dark mb-3 leading-tight group-hover:text-brand-terracota transition-colors">
            {servico.titulo}
          </h3>

          <p class="text-sm text-brand-muted leading-relaxed mb-6 flex-1">
            {servico.descricao}
          </p>

          <span class="text-sm font-semibold text-brand-green group-hover:text-brand-terracota transition-colors inline-flex items-center gap-2">
            Saiba mais
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
