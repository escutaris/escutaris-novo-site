---
const navItems = [
  { label: 'Início', href: '/' },
  { label: 'Sobre', href: '/#sobre' },
  {
    label: 'Serviços',
    href: '/#servicos',
    dropdown: [
      { label: 'Diagnóstico Psicossocial', href: '/diagnostico-dos-fatores-psicossociais-e-saude-mental-no-trabalho' },
      { label: 'Palestras', href: '/palestra' },
      { label: 'Rodas de Conversa', href: '/roda-de-conversa' },
      { label: 'Programa Contínuo', href: '/programa-continuo' },
      { label: 'Consultoria NR-1/GRO', href: '/consultoria-nr1' },
    ],
  },
  { label: 'Blog', href: '/blog' },
  { label: 'Depoimentos', href: '/#depoimentos' },
  { label: 'FAQ', href: '/#faq' },
];
---

<header
  id="header"
  class="sticky top-0 z-40 bg-brand-off-white/95 backdrop-blur-sm border-b border-brand-border transition-all duration-300"
>
  <div class="container-soft">
    <div class="flex items-center justify-between h-20">
      <a href="/" class="flex items-center" aria-label="Página inicial Escutaris">
        <img
          src="/logo-escutaris.png"
          alt="Escutaris"
          width="124"
          height="124"
          class="h-12 w-auto"
        />
      </a>

      <nav class="hidden lg:flex items-center" aria-label="Navegação principal">
        {navItems.map((item) => (
          item.dropdown ? (
            <div class="relative group">
              <a
                href={item.href}
                class="px-4 py-2 font-nav text-sm text-brand-dark hover:text-brand-terracota transition-colors flex items-center gap-1.5"
              >
                {item.label}
                <svg class="w-3 h-3 transition-transform group-hover:rotate-180" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                  <path d="M1.646 4.646a.5.5 0 0 1 .708 0L8 10.293l5.646-5.647a.5.5 0 0 1 .708.708l-6 6a.5.5 0 0 1-.708 0l-6-6a.5.5 0 0 1 0-.708" />
                </svg>
              </a>
              <div class="absolute top-full left-0 w-72 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 bg-white border border-brand-border">
                {item.dropdown.map((sub) => (
                  <a
                    href={sub.href}
                    class="block px-5 py-3 text-sm font-nav text-brand-dark hover:bg-brand-off-white-warm hover:text-brand-terracota transition-colors border-b border-brand-border last:border-b-0"
                  >
                    {sub.label}
                  </a>
                ))}
              </div>
            </div>
          ) : (
            <a
              href={item.href}
              class="px-4 py-2 font-nav text-sm text-brand-dark hover:text-brand-terracota transition-colors"
            >
              {item.label}
            </a>
          )
        ))}
      </nav>

      <div class="hidden lg:flex items-center">
        <a href="/#contato" class="btn-primary text-sm">Falar com a Escutaris</a>
      </div>

      <button
        type="button"
        id="mobile-menu-toggle"
        class="lg:hidden p-2 text-brand-dark"
        aria-label="Abrir menu"
        aria-expanded="false"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <nav
      id="mobile-menu"
      class="lg:hidden hidden pb-6 border-t border-brand-border"
      aria-label="Navegação mobile"
    >
      <div class="flex flex-col pt-2">
        {navItems.map((item) => (
          <a
            href={item.href}
            class="px-1 py-3 font-nav text-sm text-brand-dark hover:text-brand-terracota transition-colors border-b border-brand-border"
          >
            {item.label}
          </a>
        ))}
        {navItems.find(i => i.dropdown)?.dropdown?.map((sub) => (
          <a
            href={sub.href}
            class="px-4 py-2 text-xs font-nav text-brand-muted hover:text-brand-terracota transition-colors"
          >
            → {sub.label}
          </a>
        ))}
        <a href="/#contato" class="btn-primary mt-5 text-sm">Falar com a Escutaris</a>
      </div>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');

  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(isOpen));
  });

  // Fecha o menu mobile ao clicar em qualquer link (navegação por âncora na mesma página)
  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      toggle?.setAttribute('aria-expanded', 'false');
    });
  });
</script>
