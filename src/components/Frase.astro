<section class="relative isolate overflow-hidden">
  <img
    src="/textura-organica-serenidade.webp"
    alt=""
    aria-hidden="true"
    width="1672"
    height="941"
    loading="lazy"
    class="absolute inset-0 w-full h-full object-cover"
  />
  <div class="absolute inset-0 bg-brand-dark/60" aria-hidden="true"></div>

  <div class="relative container-soft py-28 md:py-40">
    <div class="reveal max-w-4xl mx-auto text-center">
      <span
        class="font-display text-6xl text-white/40 leading-none block mb-6 select-none"
        aria-hidden="true"
      >&ldquo;</span>
      <blockquote class="font-display text-3xl md:text-5xl font-bold text-white leading-snug mb-8">
        O que adoece no trabalho tem nome, tem causa e tem caminho.
      </blockquote>
      <p class="text-sm uppercase tracking-[0.18em] text-white/70">
        Dra. Ana Paula Teixeira
      </p>
    </div>
  </div>
