---
const stats = [
  { target: 72, suffix: 'h', label: 'Dashboard interativo entregue' },
  { texto: 'NR-1', label: '100% em conformidade' },
  { target: 28, suffix: '+', label: 'Anos em saúde ocupacional' },
  { texto: 'Equipe', label: 'Especialistas multidisciplinares' },
];

const whatsappUrl = 'https://api.whatsapp.com/send?phone=5571981357004&text=Ol%C3%A1%2C+gostaria+de+saber+mais+sobre+o+diagn%C3%B3stico+psicossocial';
---

<section id="hero" class="bg-brand-off-white">
  <div class="container-soft py-14 md:py-20">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">
      <div class="lg:col-span-7">
        <h1 class="text-4xl md:text-6xl lg:text-[4rem] font-display font-bold mb-6 leading-[1.04] text-brand-dark">
          A fiscalização da <span class="text-brand-green">NR-1</span> já começou. Sua empresa está em dia?
        </h1>

        <p class="text-lg md:text-xl text-brand-muted mb-10 leading-relaxed max-w-2xl">
          O diagnóstico psicossocial que a norma exige, conduzido de ponta a ponta:
          base científica validada, anonimato garantido e dashboard interativo
          entregue em até 72 horas.
        </p>

        <div class="flex flex-wrap gap-3 mb-4">
          <a href="#contato" class="btn-primary">
            Falar com um especialista
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </a>
          <a href={whatsappUrl} target="_blank" rel="noopener" class="btn-whatsapp">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
              <path d="M13.601 2.326A7.85 7.85 0 0 0 7.994 0C3.627 0 .068 3.558.064 7.926c0 1.399.366 2.76 1.057 3.965L0 16l4.204-1.102a7.9 7.9 0 0 0 3.79.965h.004c4.368 0 7.926-3.558 7.93-7.93A7.9 7.9 0 0 0 13.6 2.326zM7.994 14.521a6.6 6.6 0 0 1-3.356-.92l-.24-.144-2.494.654.666-2.433-.156-.251a6.56 6.56 0 0 1-1.007-3.505c0-3.626 2.957-6.584 6.591-6.584a6.56 6.56 0 0 1 4.66 1.931 6.56 6.56 0 0 1 1.928 4.66c-.004 3.639-2.961 6.592-6.592 6.592m3.615-4.934c-.197-.099-1.17-.578-1.353-.646-.182-.065-.315-.099-.445.099-.133.197-.513.646-.627.775-.114.133-.232.148-.43.05-.197-.1-.836-.308-1.592-.985-.59-.525-.985-1.175-1.103-1.372-.114-.198-.011-.304.088-.403.087-.088.197-.232.296-.346.1-.114.133-.198.198-.33.065-.134.034-.248-.015-.347-.05-.099-.445-1.076-.612-1.47-.16-.389-.323-.335-.445-.34-.114-.007-.247-.007-.38-.007a.73.73 0 0 0-.529.247c-.182.198-.691.677-.691 1.654s.71 1.916.81 2.049c.098.133 1.394 2.132 3.383 2.992.47.205.84.326 1.129.418.475.152.904.129 1.246.08.38-.058 1.171-.48 1.338-.943.164-.464.164-.86.114-.943-.049-.084-.182-.133-.38-.232" />
            </svg>
            Falar no WhatsApp
          </a>
        </div>

        <p class="text-sm text-brand-muted mb-10">
          Conversa inicial gratuita e sem compromisso · Resposta em até 24h úteis
        </p>

      </div>

      <div class="lg:col-span-5">
        <div class="relative">
          <img
            src="/hero-banner.webp"
            alt="Profissional apresentando dashboard de diagnóstico psicossocial e saúde mental corporativa"
            width="600"
            height="600"
            class="w-full h-auto block"
            loading="eager"
            fetchpriority="high"
          />
        </div>
      </div>
    </div>
  </div>

  <div class="border-y border-brand-border bg-white">
    <div class="container-soft">
      <div class="grid grid-cols-2 md:grid-cols-4 divide-y md:divide-y-0 md:divide-x divide-brand-border">
        {stats.map((stat) => (
          <div class="py-8 md:py-10 px-6 text-center md:text-left">
            <p class="font-display text-3xl md:text-4xl font-bold text-brand-green mb-1.5 leading-none tabular-nums">
              {stat.texto ? (
                stat.texto
              ) : (
                <span data-counter data-target={stat.target} data-suffix={stat.suffix}>
                  {stat.target}{stat.suffix}
                </span>
              )}
            </p>
            <p class="text-sm text-brand-muted leading-snug">{stat.label}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
