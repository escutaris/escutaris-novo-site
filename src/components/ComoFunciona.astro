---
const pilares = [
  {
    titulo: 'Conformidade NR-01',
    descricao: 'Diagnóstico estruturado conforme os critérios da NR-01 sobre fatores psicossociais de risco. Documentação técnica integrada ao PGR, com evidência rastreável de avaliação para fiscalização, auditoria e relatórios ESG.',
  },
  {
    titulo: 'Base científica',
    descricao: 'Questionários cientificamente validados e adaptados para psicologia do trabalho e saúde ocupacional. Sem instrumentos genéricos: apenas ferramentas com evidência publicada e validação cultural para o contexto brasileiro.',
  },
  {
    titulo: 'Dashboard interativo',
    descricao: 'Plataforma visual com filtros por setor, função, faixa etária e jornada de trabalho. Análise multifator que identifica padrões e orienta intervenção, não apenas mede percepção em médias agregadas.',
  },
  {
    titulo: 'Confidencialidade e LGPD',
    descricao: 'Anonimato de origem garantido por arquitetura técnica, não por promessa institucional. Resultados agregados, dados pessoais segregados, conformidade integral com a Lei Geral de Proteção de Dados.',
  },
];
---

<section id="como-funciona" class="section-pad bg-white">
  <div class="container-soft">
    <div class="reveal max-w-4xl mb-16 md:mb-20">
      <span class="eyebrow mb-5">Como funciona</span>
      <h2 class="text-3xl md:text-5xl font-display font-bold mb-6 leading-[1.1] text-brand-dark">
        Quatro pilares técnicos.
      </h2>
      <p class="text-lg md:text-xl text-brand-muted leading-relaxed">
        O que diferencia um diagnóstico psicossocial sério de uma pesquisa de clima recauchutada.
      </p>
    </div>

    <div class="border border-brand-border bg-brand-off-white grid grid-cols-1 md:grid-cols-2">
      {pilares.map((pilar, i) => (
        <article class:list={[
          'p-8 md:p-12 border-brand-border',
          i < pilares.length - 1 && 'border-b',
          i >= pilares.length - 2 && 'md:border-b-0',
          i % 2 === 0 && 'md:border-r',
        ]}>
          <span class="font-display text-5xl md:text-6xl font-bold text-brand-terracota leading-none mb-6 block">
            0{i + 1}
          </span>

          <h3 class="text-xl md:text-2xl font-display font-bold text-brand-dark mb-4 leading-tight">
            {pilar.titulo}
          </h3>

          <p class="text-brand-muted leading-relaxed">
            {pilar.descricao}
          </p>
        </article>
      ))}
    </div>
  </div>
</section>
