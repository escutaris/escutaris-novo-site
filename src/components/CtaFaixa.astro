---
// Faixa de chamada para ação, repetida ao longo da home para manter o visitante
// sempre a um clique do contato (padrão de página comercial).
interface Props {
  titulo: string;
  subtitulo?: string;
}

const { titulo, subtitulo } = Astro.props;

const whatsappUrl =
  'https://api.whatsapp.com/send?phone=5571981357004&text=Ol%C3%A1%2C+quero+falar+com+um+especialista+da+Escutaris';
---

<section class="bg-brand-green">
  <div class="container-soft py-10 md:py-12">
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
      <div>
        <p class="font-display font-bold text-white text-xl md:text-2xl leading-tight">
          {titulo}
        </p>
        {subtitulo && (
          <p class="text-white/75 text-sm md:text-base mt-1.5">{subtitulo}</p>
        )}
      </div>
      <div class="flex flex-wrap gap-3 flex-shrink-0">
        <a
          href="#contato"
          class="inline-flex items-center gap-2 px-6 py-3 bg-white text-brand-green font-semibold hover:bg-brand-off-white-warm transition-colors"
        >
          Falar com um especialista
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        </a>
        <a href={whatsappUrl} target="_blank" rel="noopener" class="btn-whatsapp">
          Falar no WhatsApp
        </a>
      </div>
    </div>
  </div>
</section>
